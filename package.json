    "@nextcloud/router": "^3.1.0",
    "@nextcloud/vue": "^9.5.0",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@nextcloud/browserslist-config": "^3.1.2",
    "@nextcloud/vite-config": "^2.5.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
